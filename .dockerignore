# ==========================================
# Version Control - Don't copy into image
# ==========================================
.git
.gitignore
.gitattributes
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Jenkinsfile

# ==========================================
# Docker files - Already used, don't include
# ==========================================
Dockerfile*
docker-compose*.yml
.docker/

# ==========================================
# Documentation - Not needed in production
# ==========================================
*.md
README*
CHANGELOG*
LICENSE*
CONTRIBUTING*
docs/
documentation/

# ==========================================
# CI/CD & Scripts
# ==========================================
.github/
.gitlab/
scripts/local/
setup-ssl.sh
deploy.sh

# ==========================================
# Python - Will be regenerated
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
*.pyo
*.pyd

# Virtual environments - Don't copy, pip install fresh
venv/
env/
ENV/
.venv
env.bak/
venv.bak/
.pixi/
__pypackages__/

# Python testing - Not needed in production
.pytest_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
cover/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.cache

# Type checking & linting - Development only
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/
.ruff_cache/

# Build artifacts - Will be rebuilt
build/
dist/
*.egg-info/
.eggs/
*.egg
wheels/
share/python-wheels/
.pybuilder/
target/

# ==========================================
# Django - Generated or not needed
# ==========================================
*.log
local_settings.py
# Note: db.sqlite3 is not needed in production
# db.sqlite3
db.sqlite3-journal

# Static/media - will be collected/generated in container
staticfiles/
media/
static_volume/

# ==========================================
# Database & Data Volumes - CRITICAL!
# ==========================================
postgres_data/
redis_data/
*_data/
*.sql
*.dump
*.sql.gz
*.dump.gz
backup/
backups/
*.rdb
*.aof

# ==========================================
# SSL & Certificates - CRITICAL!
# ==========================================
certbot/
*.pem
*.key
*.crt
*.csr
*.cer
*.p12
*.pfx

# ==========================================
# Environment files - use env_file in compose
# ==========================================
.env*
!.env.example
.envrc

# ==========================================
# IDE & Editors - Personal configs
# ==========================================
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.abstra/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# ==========================================
# Celery
# ==========================================
celerybeat-schedule
celerybeat.pid
celery_worker_state

# ==========================================
# Node - If you have frontend
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
package-lock.json
yarn.lock

# ==========================================
# Jupyter & Notebooks - Development only
# ==========================================
.ipynb_checkpoints
*.ipynb
profile_default/
ipython_config.py

# ==========================================
# Logs - Will be generated in container
# ==========================================
logs/
nginx/logs/
nginx/*.log

# ==========================================
# Temporary & Cache
# ==========================================
tmp/
temp/
*.tmp
*.bak
*.backup

# ==========================================
# Nginx temporary configs
# ==========================================
nginx/nginx-temp.conf
nginx/*.backup

# ==========================================
# Security - NEVER include in image
# ==========================================
.keys/
.pypirc

# RabbitMQ
mnesia/
rabbitmq/
rabbitmq-data/

# ActiveMQ
activemq-data/

# Streamlit
.streamlit/secrets.toml

# Marimo
marimo/_static/
marimo/_lsp/
__marimo__/
